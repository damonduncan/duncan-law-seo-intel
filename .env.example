# ─────────────────────────────────────────────
# Database (from Railway PostgreSQL plugin)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# ─────────────────────────────────────────────
# Google OAuth 2.0 (dashboard login)
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs: http://localhost:8000/auth/callback AND https://your-app.railway.app/auth/callback
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/callback
ALLOWED_EMAIL_DOMAIN=duncanlawonline.com

# ─────────────────────────────────────────────
# Session security (generate with: openssl rand -hex 32)
# ─────────────────────────────────────────────
SECRET_KEY=

# ─────────────────────────────────────────────
# DataForSEO (create account at dataforseo.com)
# ─────────────────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─────────────────────────────────────────────
# Google Places API (New)
# Enable at: console.cloud.google.com → APIs → Places API (New)
# ─────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─────────────────────────────────────────────
# Google Business Profile API (own firm daily data)
# Requires separate API approval from Google (1-5 days)
# Paste the entire service account JSON as a single-line string
# ─────────────────────────────────────────────
GOOGLE_BUSINESS_PROFILE_CREDENTIALS=
USE_BUSINESS_PROFILE_API=false

# ─────────────────────────────────────────────
# PACER (your existing account credentials)
# ─────────────────────────────────────────────
PACER_USERNAME=
PACER_PASSWORD=
PACER_CLIENT_CODE=
PACER_PASSWORD_EXPIRES=2027-01-01

# ─────────────────────────────────────────────
# Resend (email digest)
# Create account at resend.com, verify duncanlawonline.com domain
# ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_ADDRESS=alerts@duncanlawonline.com
DIGEST_RECIPIENT=damonduncan@duncanlawonline.com

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
APP_BASE_URL=https://your-app.railway.app
ENVIRONMENT=development
LOG_LEVEL=INFO
